rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Basic security: only auth'd users can read/write their own stuff, no schema limits
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid || request.resource.data.ownerId == request.auth.uid || document.matches('^settings/'+request.auth.uid+'$'));
    }
  }
}
